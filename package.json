    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.2.0",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.3.0",
    "jsdom": "^29.0.2",
    "juice": "^10.0.1",
