<html lang='en'>
  <head>
    <meta name='color-scheme' content='light dark' />
    <meta name='supported-color-schemes' content='light dark' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta http-equiv='Content-Type' content='text/html; charset=UTF-8' />
    <meta name='format-detection' content='telephone=no, date=no, address=no' />
    <link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap' rel='stylesheet' />
    <title>{{subject}}</title>
    <style>
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      body {
        margin: 0;
        padding: 0;
        background-color: #060d18;
        font-family:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        font-size: 15px;
        line-height: 1.6;
        color: #94a3b8;
      }

      .wrapper {
        width: 100%;
        table-layout: fixed;
        background-color: #060d18;
        padding: 20px 0 40px 0;
      }

      .main {
        max-width: 600px;
        margin: 0 auto;
        background-color: #0d1f35;
        border: 1px solid #1e293b;
        border-radius: 8px;
        overflow: hidden;
      }

      .header {
        background-color: #0a1628;
        padding: 24px 32px;
        border-bottom: 1px solid #1e293b;
      }

      .brand {
        color: #00c896;
        font-size: 18px;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: -0.5px;
        display: inline-block;
        font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
      }

      .brand-sub {
        color: #64748b;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-top: 4px;
        display: block;
      }

      .content {
        padding: 32px;
      }

      .notification-meta {
        margin-bottom: 20px;
      }

      .protocol-label {
        font-size: 12px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
        font-weight: 600;
      }

      .protocol-name {
        font-size: 14px;
        color: #00c896;
        font-weight: 600;
        font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
        letter-spacing: -0.3px;
      }

      .category-badge {
        display: inline-block;
        background-color: #00c896;
        color: #0a1628;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 16px;
      }
      .category-badge.security {
        background-color: #ef4444;
        color: #ffffff;
      }
      .category-badge.governance {
        background-color: #8b5cf6;
        color: #ffffff;
      }
      .category-badge.liquidation {
        background-color: #ef4444;
        color: #ffffff;
      }
      .category-badge.system {
        background-color: #f59e0b;
        color: #0a1628;
      }
      .category-badge.yield {
        background-color: #10b981;
        color: #0a1628;
      }

      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #f8fafc;
        line-height: 1.3;
        margin: 0 0 20px 0;
        letter-spacing: -0.3px;
      }

      .body-text {
        color: #94a3b8;
        font-size: 15px;
        line-height: 1.7;
        margin: 0;
      }

      .body-text p {
        margin: 0 0 16px 0;
      }

      .body-text p:last-child {
        margin-bottom: 0;
      }

      .body-text strong {
        color: #e2e8f0;
        font-weight: 600;
      }

      .body-text a {
        color: #00c896;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .data-block {
        background-color: #071520;
        border: 1px solid #1e293b;
        border-radius: 6px;
        padding: 16px;
        margin: 20px 0 0 0;
      }

      .data-label {
        font-size: 10px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        font-weight: 600;
      }

      .data-value {
        font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
        font-size: 13px;
        color: #cbd5e1;
        word-break: break-all;
        line-height: 1.5;
      }

      .action {
        margin-top: 24px;
      }

      .button {
        display: inline-block;
        background-color: #00c896;
        color: #0a1628;
        padding: 12px 24px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: none;
      }

      .footer-border {
        background-color: #071520;
        border-top: 1px solid #1e293b;
        padding: 16px 32px;
      }

      .privacy-notice {
        font-size: 12px;
        color: #475569;
        text-align: center;
        font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
        line-height: 1.5;
      }

      .privacy-notice strong {
        color: #00c896;
        font-weight: 600;
      }

      .footer {
        padding: 24px 32px;
        font-size: 12px;
        color: #475569;
        text-align: center;
        line-height: 1.8;
      }

      .footer a {
        color: #64748b;
        text-decoration: underline;
      }

      .footer-divider {
        color: #1e293b;
        margin: 0 8px;
      }

      .herald-link {
        color: #00c896 !important;
        text-decoration: none !important;
        font-weight: 600;
      }

      .address {
        font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
        font-size: 11px;
        color: #334155;
        margin-top: 8px;
        word-break: break-all;
      }

      @media only screen and (max-width: 600px) {
        .wrapper {
          padding: 0;
        }
        .main {
          width: 100% !important;
          border-radius: 0 !important;
          border-left: none;
          border-right: none;
        }
        .content {
          padding: 24px !important;
        }
        .header {
          padding: 20px 24px !important;
        }
        h1 {
          font-size: 20px !important;
        }
        .button {
          display: block;
          text-align: center;
        }
      }

      @media (prefers-color-scheme: dark) {
        body {
          background-color: #060d18 !important;
        }
        .main {
          background-color: #0d1f35 !important;
        }
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <table
        role='presentation'
        border='0'
        cellpadding='0'
        cellspacing='0'
        width='100%'
      >
        <tr>
          <td align='center'>
            <table
              role='presentation'
              border='0'
              cellpadding='0'
              cellspacing='0'
              class='main'
              width='600'
              style='max-width: 600px;'
            >

              <!-- Header -->
              <tr>
                <td class='header'>
                  <table
                    role='presentation'
                    border='0'
                    cellpadding='0'
                    cellspacing='0'
                    width='100%'
                  >
                    <tr>
                      <td>
                        <table
                          role='presentation'
                          border='0'
                          cellpadding='0'
                          cellspacing='0'
                        >
                          <tr>
                            <td valign='middle' style='padding-right: 12px;'>
                              <img
                                src='https://ucshdejvxzanuxlxrano.supabase.co/storage/v1/object/public/herald-public-asset/herald-logo.svg'
                                alt='Herald Logo'
                                width='32'
                                height='32'
                                style='display: block; border-radius: 4px; background-image: linear-gradient(transparent, transparent);'
                              />
                            </td>
                            <td valign='middle'>
                              <span class='brand'>HERALD</span>
                              <span class='brand-sub'>Notification
                                Infrastructure</span>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <!-- Content -->
              <tr>
                <td class='content'>
                  <div
                    class='category-badge {{categoryClass category}}'
                  >{{category}}</div>
                  <div class='notification-meta'>
                    <div class='protocol-label'>Source Protocol</div>
                    <div class='protocol-name'>{{protocolName}}</div>
                  </div>

                  <h1>{{subject}}</h1>

                  <div class='body-text'>
                    {{markdown body}}
                  </div>

                  {{#if txHash}}
                    <div class='data-block'>
                      <div class='data-label'>Transaction Reference</div>
                      <div class='data-value'>{{txHash}}</div>
                    </div>
                  {{/if}}

                  {{#if actionUrl}}
                    <div class='action'>
                      <a href='{{actionUrl}}' class='button'>{{#if
                          actionLabel
                        }}{{actionLabel}}{{else}}View Details{{/if}}</a>
                    </div>
                  {{/if}}
                </td>
              </tr>

              <!-- Privacy Footer -->
              <tr>
                <td class='footer-border'>
                  <div class='privacy-notice'>
                    Zero-PII delivery protocol •
                    <strong>{{protocolName}}</strong>
                    cannot access recipient identity • Relayed by Herald Network
                  </div>
                </td>
              </tr>

            </table>

            <!-- External Footer -->
            <table
              role='presentation'
              border='0'
              cellpadding='0'
              cellspacing='0'
              width='600'
              style='max-width: 600px; margin: 0 auto;'
            >
              <tr>
                <td class='footer'>
                  Delivered via Herald API
                  <span class='footer-divider'>|</span>
                  <a
                    href='https://useherald.xyz'
                    class='herald-link'
                  >useherald.xyz</a>
                  <br />
                  <a href='{{unsubscribeUrl}}'>Unsubscribe from
                    {{protocolName}}
                    notifications</a>
                  <br />
                  <span class='address'>{{recipientAddress}}</span>
                </td>
              </tr>
            </table>

          </td>
        </tr>
      </table>
    </div>
  </body>
</html>