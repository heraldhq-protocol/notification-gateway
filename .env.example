# ──────────────────────────────────────────────────────────────────────────────
# Herald Notification Gateway — Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# development | staging | production | test
NODE_ENV=development
PORT=3000
API_VERSION=v1
SERVICE_NAME=herald-gateway

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev:   postgresql://user:password@localhost:5432/herald?schema=public
# Supabase:    postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/herald_gateway?schema=public"
# Direct connection bypasses pgBouncer — required for Prisma migrations
DIRECT_URL="postgresql://user:password@localhost:5432/herald_gateway?schema=public"
# Connection pool sizing (defaults are fine for most deployments)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis (BullMQ, Rate Limiting, PDA Cache) ──────────────────────────────────
# Local:         redis://localhost:6379
# Upstash TLS:   rediss://default:PASSWORD@HOST:6379
# ElastiCache:   bare host:port (e.g. my-cluster.abc.use1.cache.amazonaws.com:6379)
REDIS_URL="redis://localhost:6379"
# Set to true when pointing at an ElastiCache Cluster-Mode endpoint
REDIS_CLUSTER_MODE=false
# Override TLS detection. Auto-detected for *.cache.amazonaws.com and *.upstash.io
# REDIS_TLS=false

# ── Solana ────────────────────────────────────────────────────────────────────
# Primary RPC endpoint (Helius, QuickNode, etc.)
SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
# Optional secondary endpoint for circuit-breaker failover
SOLANA_FALLBACK_RPC_URL="https://api.mainnet-beta.solana.com"
# On-chain Herald Program ID
HERALD_PROGRAM_ID="2pxjAf8tLCakKVDuN4vY51B5TeaEQk4koPuk9NZvWqdf"
# Devnet program ID (used in testing / sandbox)
HERALD_DEVNET_PROGRAM_ID="2pxjAf8tLCakKVDuN4vY51B5TeaEQk4koPuk9NZvWqdf"

# ── Herald Authority ──────────────────────────────────────────────────────────
# Development: raw Base58-encoded keypair secret (never use in production)
HERALD_AUTHORITY_SECRET="base58-encoded-secret-key"
DEV_AUTHORITY_KEYPAIR_PATH="./dev-authority-keypair.json"
# Production: KMS-wrapped ciphertext (set these instead of HERALD_AUTHORITY_SECRET)
HERALD_AUTHORITY_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/xxx"
HERALD_AUTHORITY_SECRET_CIPHERTEXT="hex-encoded-ciphertext"

# ── Enclave / X25519 Encryption ───────────────────────────────────────────────
# Enclave mode: production | sandbox | development
ENCLAVE_MODE=sandbox
# X25519 private key — used in dev/sandbox when KMS is not active (64 hex chars)
HERALD_X25519_PRIV_HEX="64-char-hex-string"
# Production: KMS-wrapped X25519 key
AWS_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/yyy"
HERALD_X25519_PRIV_CIPHERTEXT="hex-encoded-ciphertext"
# nacl.secretbox key for sandbox E2E encryption tests (portal + gateway must match)
# Generate: node -e "const nacl=require('tweetnacl');console.log(Buffer.from(nacl.randomBytes(32)).toString('base64'))"
ENCLAVE_TEST_KEY="kkNlpXYSlFFy1m7lLCXiBTaX9pH/h7fmrhZvprITd5w="
# Nitro Enclave Unix socket (production only)
NITRO_ENCLAVE_SOCKET="/run/enclave.sock"

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="secret"
# AWS Secrets Manager secret ID (production — loads full config from Secrets Manager)
# SECRET_ID="herald/gateway/prod"

# ── Email Provider ────────────────────────────────────────────────────────────
# smtp | resend | ses
MAIL_PROVIDER=smtp

# SMTP — development / local Mailhog
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER="user"
SMTP_PASS="pass"
SMTP_FROM="noreply@useherald.xyz"

# Resend — staging
RESEND_API_KEY="re_xxx"

# AWS SES — production
SES_FROM_ADDRESS="noreply@useherald.xyz"
SES_REGION="us-east-1"
SES_CONFIGURATION_SET="herald-production"

# SendGrid — fallback
SENDGRID_API_KEY="SG.xxx"

# Redirect real emails to developer addresses in development (JSON map: wallet → email)
DEV_DEBUG_EMAILS='{}'

# ── DKIM ──────────────────────────────────────────────────────────────────────
DKIM_DOMAIN="useherald.xyz"
DKIM_KEY_SELECTOR="herald2026"
# KMS key used for DKIM signing
DKIM_KMS_KEY_ID="alias/herald-dkim-signer"

# ── Irys / Arweave (Permanent Receipt Storage) ────────────────────────────────
IRYS_NODE="https://node1.irys.xyz"
# IRYS_TOKEN="your-irys-token"
# Legacy Arweave wallet path (deprecated — use IRYS_NODE/IRYS_TOKEN instead)
# ARWEAVE_WALLET_PATH="/path/to/wallet.json"

# ── Light Protocol (ZK Compression Receipts) ──────────────────────────────────
# RPC for getValidityProof calls (e.g. Helius or dedicated Photon endpoint)
LIGHT_RPC_URL="http://localhost:8784"
# Merkle tree address for appending ZK receipts
LIGHT_OUTPUT_TREE="your-output-tree-pubkey"
HERALD_MERKLE_TREE_ADDRESS="your-merkle-tree-address"
# How many receipts to submit per batch transaction
RECEIPT_BATCH_SIZE=20

# ── Helio Billing ─────────────────────────────────────────────────────────────
HELIO_API_KEY="helio_xxxxxxxxxxxxx"
HELIO_SECRET_KEY="helio_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
HELIO_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
HELIO_API_BASE="https://api.hel.io/v1"
# Wallet ID — from Helio Dashboard → Settings → Wallets → Copy wallet ID
HELIO_WALLET_ID="your-helio-wallet-id"
# mainnet | devnet
HELIO_NETWORK="mainnet"
HELIO_TEMPLATE_GROWTH="tpl_herald_growth_xxxx"
HELIO_TEMPLATE_SCALE="tpl_herald_scale_xxxx"
HELIO_TEMPLATE_ENTERPRISE="tpl_herald_enterprise_xxxx"
HELIO_TEMPLATE_OVERCHARGE="tpl_herald_overcharge_xxxx"
HELIO_CHECKOUT_SUCCESS_URL="https://app.useherald.xyz/billing/success"
HELIO_CHECKOUT_CANCEL_URL="https://app.useherald.xyz/billing"
# USDC currency IDs from Helio (used for on-chain billing)
USDC_CURRENCY_ID_MAINNET="6340313846e4f91b8abc519b"
USDC_CURRENCY_ID_DEVNET="63430c8348c610068bcdc482"

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET="development-webhook-secret-32chars!!"
WEBHOOK_MAX_RETRIES=3
WEBHOOK_AUTO_DISABLE_THRESHOLD=10
# Allow webhooks to localhost/private IPs (development only — never true in prod)
ALLOW_LOCAL_WEBHOOKS=false

# ── Unsubscribe ───────────────────────────────────────────────────────────────
UNSUBSCRIBE_BASE_URL="https://notify.useherald.xyz"
# Generate with: openssl rand -base64 32
UNSUBSCRIBE_JWT_SECRET="development-unsub-jwt-secret-32!!"

# ── Internal Service Auth ─────────────────────────────────────────────────────
# Shared secret for herald-admin-api → herald-gateway internal calls
# Must match INTERNAL_API_KEY in the Admin API. Generate: openssl rand -base64 32
INTERNAL_API_KEY="your-internal-api-key-here"

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ── SMS (AWS SNS) ─────────────────────────────────────────────────────────────
# Sender ID shown on recipient's phone (max 11 chars, alphanumeric)
SNS_SENDER_ID="Herald"

# ── Testing ───────────────────────────────────────────────────────────────────
# Solana keypair used only in local/test environments (base58 encoded)
TEST_SECRET_KEY="REPLACE_WITH_TEST_KEYPAIR_BASE58"

# ── SES Event Notifications (SQS) ─────────────────────────────────────
# Queue URL for SES bounce/complaint/delivery notifications via SNS → SQS.
# If set, the SqsConsumerService will poll this queue and enqueue
# notifications for processing. Leave unset to disable SQS polling.
# SQS_SES_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/ACCOUNT/herald-ses-events"

# ── AI Content Moderation ─────────────────────────────────────────────────────
# Provider: "anthropic" (default) | "openai"
AI_PROVIDER=anthropic

# Anthropic — used when AI_PROVIDER=anthropic
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
# Model override (default: claude-haiku-4-5-20251001 — fastest + cheapest)
# Other options: claude-sonnet-4-6, claude-opus-4-7
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — used when AI_PROVIDER=openai
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
# Base URL override — point at Azure OpenAI, Groq, Ollama, Together, etc.
# Leave unset to use the OpenAI default (https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Observability ─────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
PINO_LOG_LEVEL=debug
# Legacy alias — prefer PINO_LOG_LEVEL
# LOG_LEVEL=debug
# Redact PII fields in log output
PII_REDACTION=true
# OpenTelemetry collector endpoint (optional)
# OTEL_EXPORTER_URL="http://localhost:4318"
# Sentry DSN (optional)
# SENTRY_DSN="https://xxx@o0.ingest.sentry.io/0"
