# ──────────────────────────────────────────────────────────────────────
# Herald Notification Gateway — Environment Configuration
# ──────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────
# development | staging | production
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Get from a managed DB provider or local Docker (docker-compose.dev.yml)
DATABASE_URL="postgresql://user:password@localhost:5432/herald?schema=public"

# ── Redis (BullMQ, Rate Limiting, PdaCache) ───────────────────────────
# Connection string for BullMQ and generic Redis usage
REDIS_URL="redis://localhost:6379"

# ── Security ──────────────────────────────────────────────────────────
# Secret for signing JWTs or other internal hashes
JWT_SECRET="generate-a-long-random-string"

# ── Solana (Mainnet/Devnet) ───────────────────────────────────────────
# SOLANA_RPC_URL: Primary RPC endpoint (Helius, QuickNode, etc.)
# SOLANA_FALLBACK_RPC_URL: Optional secondary endpoint for circuit breaker
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_FALLBACK_RPC_URL="https://api.mainnet-beta.solana.com"

# The on-chain Herald Program ID
HERALD_PROGRAM_ID="2pxjAf8tLCakKVDuN4vY51B5TeaEQk4koPuk9NZvWqdf"

# Authority Keypair (Base58 encoded secret key)
# Used for writing ZK receipts to the registry
HERALD_AUTHORITY_SECRET="base58-encoded-secret-key"

# AWS KMS Configuration (Production)
# If set, the gateway will unwrap HERALD_AUTHORITY_SECRET_CIPHERTEXT via KMS
HERALD_AUTHORITY_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/xxx"
HERALD_AUTHORITY_SECRET_CIPHERTEXT="hex-encoded-ciphertext"

# Development only (never in production)
DEV_AUTHORITY_KEYPAIR_PATH="./dev-authority-keypair.json"

# ── Helio Billing (Phase 1) ───────────────────────────────────────────
HELIO_API_KEY="helio_xxxxxxxxxxxxx"
HELIO_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
HELIO_SECRET_KEY="helio_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
HELIO_TEMPLATE_GROWTH="tpl_herald_growth_xxxx"
HELIO_TEMPLATE_SCALE="tpl_herald_scale_xxxx"
HELIO_TEMPLATE_ENTERPRISE="tpl_herald_enterprise_xxxx"
HELIO_CHECKOUT_SUCCESS_URL="https://app.useherald.xyz/billing/success"
HELIO_CHECKOUT_CANCEL_URL="https://app.useherald.xyz/billing"

# ── Light Protocol (Stateless Compression) ──────────────────────────
# RPC for getValidityProof calls (e.g. Helius or private Light RPC)
LIGHT_RPC_URL="https://mainnet.helius-rpc.com/?api-key=your-key"
# Merkle tree address for appending receipts
LIGHT_OUTPUT_TREE="your-output-tree-pubkey"

# ── Email Providers ───────────────────────────────────────────────────

MAIL_PROVIDER=resend

# SMTP (Development/Fallback)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER="user"
SMTP_PASS="pass"
SMTP_FROM="noreply@useherald.xyz"

# Resend (Staging)
RESEND_API_KEY="re_xxx"

DEV_DEBUG_EMAILS='{"9TXw1ZfG...": "your-real-email@gmail.com"}'


# AWS SES (Production)
# Requires AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY + AWS_REGION in env
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="secret"

# SendGrid (Fallback)
SENDGRID_API_KEY="SG.xxx"

# ── DKIM (AWS KMS) ───────────────────────────────────────────────────
# KMS Key ID for signing DKIM keys
DKIM_KMS_KEY_ID="alias/herald-dkim-signer"

# ── Arweave (Permanent Storage) ──────────────────────────────────────
# Path to Arweave wallet JSON for Irys/Bundlr
ARWEAVE_WALLET_PATH="/path/to/wallet.json"

# ── Observability ─────────────────────────────────────────────────────
# Redact PII in logs
LOG_LEVEL=debug
PII_REDACTION=true

# ── Telegram Bot ──────────────────────────────────────────────────────
# Bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ── SMS (AWS SNS) ─────────────────────────────────────────────────────
# SMS sender ID shown on recipient's phone (max 11 chars, alphanumeric)
SNS_SENDER_ID="Herald"

# ── Webhooks ──────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET="development-webhook-secret-32chars!!"
ALLOW_LOCAL_WEBHOOKS=false

# ── Sandbox / Enclave (Testing) ─────────────────────────────────────────
# Enclave mode: production | sandbox | development
# In sandbox/development/test, uses ENCLAVE_TEST_KEY for decryption
ENCLAVE_MODE=sandbox

# X25519 Private Key (Hex) — used in development/sandbox if KMS is not active
HERALD_X25519_PRIV_HEX="64-char-hex-string"

# AWS KMS Configuration (Production)
# If set, the gateway will unwrap HERALD_X25519_PRIV_CIPHERTEXT via KMS
AWS_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/yyy"
HERALD_X25519_PRIV_CIPHERTEXT="hex-encoded-ciphertext"

# 32-byte base64 key for nacl.secretbox decryption in sandbox mode.
# Generate with: node -e "const nacl = require('tweetnacl'); console.log(Buffer.from(nacl.randomBytes(32)).toString('base64'))"
# Both portal and gateway must use the same key for end-to-end encryption testing
ENCLAVE_TEST_KEY="kkNlpXYSlFFy1m7lLCXiBTaX9pH/h7fmrhZvprITd5w="

# Nitro Enclave socket path (production only)
# Default: /run/enclave.sock
NITRO_ENCLAVE_SOCKET="/run/enclave.sock"

# ── Internal Service Auth ────────────────────────────────────────────
# Shared secret for herald-admin-api → herald-gateway internal calls
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY="your-internal-api-key-here"
