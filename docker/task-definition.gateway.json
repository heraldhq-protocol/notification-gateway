{
  "family": "herald-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-task-role",
  "volumes": [
    {
      "name": "enclave-socket"
    }
  ],
  "containerDefinitions": [
    {
      "name": "gateway",
      "image": "PLACEHOLDER_GATEWAY_IMAGE",
      "essential": true,
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "mountPoints": [
        { "sourceVolume": "enclave-socket", "containerPath": "/run", "readOnly": false }
      ],
      "environment": [
        { "name": "NODE_ENV",                        "value": "production" },
        { "name": "PORT",                            "value": "3000" },
        { "name": "API_VERSION",                     "value": "v1" },
        { "name": "SERVICE_NAME",                    "value": "herald-gateway" },
        { "name": "ENCLAVE_MODE",                    "value": "sandbox" },
        { "name": "SECRET_ID",                       "value": "herald-gateway/staging" },
        { "name": "NODE_TLS_REJECT_UNAUTHORIZED",    "value": "0" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",               "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:DATABASE_URL::" },
        { "name": "REDIS_URL",                  "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:REDIS_URL::" },
        { "name": "JWT_SECRET",                 "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:JWT_SECRET::" },
        { "name": "SOLANA_RPC_URL",             "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:SOLANA_RPC_URL::" },
        { "name": "HERALD_PROGRAM_ID",          "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HERALD_PROGRAM_ID::" },
        { "name": "AWS_REGION",                 "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:AWS_REGION::" },
        { "name": "MAIL_PROVIDER",              "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:MAIL_PROVIDER::" },
        { "name": "RESEND_API_KEY",             "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:RESEND_API_KEY::" },
        { "name": "SES_FROM_ADDRESS",           "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:SES_FROM_ADDRESS::" },
        { "name": "SES_REGION",                 "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:SES_REGION::" },
        { "name": "HELIO_API_KEY",              "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_API_KEY::" },
        { "name": "HELIO_SECRET_KEY",           "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_SECRET_KEY::" },
        { "name": "HELIO_WEBHOOK_SECRET",       "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_WEBHOOK_SECRET::" },
        { "name": "HELIO_TEMPLATE_GROWTH",      "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_TEMPLATE_GROWTH::" },
        { "name": "HELIO_TEMPLATE_SCALE",       "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_TEMPLATE_SCALE::" },
        { "name": "HELIO_TEMPLATE_ENTERPRISE",  "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_TEMPLATE_ENTERPRISE::" },
        { "name": "HELIO_CHECKOUT_SUCCESS_URL", "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_CHECKOUT_SUCCESS_URL::" },
        { "name": "HELIO_CHECKOUT_CANCEL_URL",  "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_CHECKOUT_CANCEL_URL::" },
        { "name": "WEBHOOK_SIGNING_SECRET",     "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:WEBHOOK_SIGNING_SECRET::" },
        { "name": "UNSUBSCRIBE_BASE_URL",       "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:UNSUBSCRIBE_BASE_URL::" },
        { "name": "UNSUBSCRIBE_JWT_SECRET",     "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:UNSUBSCRIBE_JWT_SECRET::" },
        { "name": "PINO_LOG_LEVEL",             "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:PINO_LOG_LEVEL::" },
        { "name": "HELIO_TEMPLATE_OVERCHARGE",  "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HELIO_TEMPLATE_OVERCHARGE::" },
        { "name": "INTERNAL_API_KEY",           "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:INTERNAL_API_KEY::" },
        { "name": "HERALD_AUTHORITY_SECRET",    "valueFrom": "arn:aws:secretsmanager:eu-north-1:120822896955:secret:herald-gateway/staging:HERALD_AUTHORITY_SECRET::" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/health/live || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "dependsOn": [
        { "containerName": "mock-enclave", "condition": "HEALTHY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/herald-gateway",
          "awslogs-region":        "eu-north-1",
          "awslogs-stream-prefix": "gateway"
        }
      }
    },
    {
      "name": "mock-enclave",
      "image": "PLACEHOLDER_ENCLAVE_IMAGE",
      "essential": true,
      "mountPoints": [
        { "sourceVolume": "enclave-socket", "containerPath": "/run", "readOnly": false }
      ],
      "environment": [
        { "name": "SOCKET_PATH", "value": "/run/enclave.sock" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "test -S /run/enclave.sock || exit 1"],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/herald-gateway",
          "awslogs-region":        "eu-north-1",
          "awslogs-stream-prefix": "mock-enclave"
        }
      }
    }
  ]
}
