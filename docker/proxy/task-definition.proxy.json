{
  "family": "herald-proxy",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "nginx-proxy",
      "image": "120822896955.dkr.ecr.eu-north-1.amazonaws.com/herald-proxy:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 80, "protocol": "tcp" },
        { "containerPort": 443, "protocol": "tcp" }
      ],
      "mountPoints": [
        {
          "sourceVolume": "herald-ssl-certs",
          "containerPath": "/etc/nginx/ssl",
          "readOnly": true
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/herald-proxy",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "proxy"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "herald-ssl-certs",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0fc89d5fd37587dfb",
        "rootDirectory": "/letsencrypt",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "iam": "ENABLED"
        }
      }
    }
  ]
}
