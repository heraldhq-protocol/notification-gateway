{
  "family": "efs-init",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "init",
      "image": "alpine:latest",
      "essential": true,
      "command": [
        "sh", "-c",
        "mkdir -p /mnt/efs/letsencrypt && chmod 755 /mnt/efs/letsencrypt && echo 'Done' && ls /mnt/efs"
      ],
      "mountPoints": [
        {
          "sourceVolume": "herald-ssl-certs",
          "containerPath": "/mnt/efs",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/herald-proxy",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "efs-init"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "herald-ssl-certs",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0fc89d5fd37587dfb",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-06de016391033b2ea",
          "iam": "ENABLED"
        }
      }
    }
  ]
}