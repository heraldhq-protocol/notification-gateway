{
  "family": "certbot-init",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::120822896955:role/herald-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "certbot",
      "image": "certbot/dns-route53:latest",
      "essential": true,
      "command": [
        "certonly",
        "--dns-route53",
        "--non-interactive",
        "--agree-tos",
        "--email", "herald.admin@gmail.com",
        "-d", "api.useherald.xyz",
        "-d", "api.register.useherald.xyz"
      ],
      "mountPoints": [
        {
          "sourceVolume": "herald-ssl-certs",
          "containerPath": "/etc/letsencrypt",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/herald-proxy",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "certbot"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "herald-ssl-certs",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0fc89d5fd37587dfb",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-06de016391033b2ea",
          "iam": "ENABLED"
        }
      }
    }
  ]
}