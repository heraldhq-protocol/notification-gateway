generator client {
  provider = "prisma-client-js"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Protocol {
  id                     String                  @id @default(uuid()) @db.Uuid
  protocolPubkey         String                  @unique @map("protocol_pubkey") @db.VarChar(44)
  nameEncrypted          Bytes                   @map("name_encrypted")
  tier                   Int                     @default(0) @db.SmallInt
  isActive               Boolean                 @default(true) @map("is_active")
  isSuspended            Boolean                 @default(false) @map("is_suspended")
  sendsThisPeriod        BigInt                  @default(0) @map("sends_this_period")
  overageEnabled         Boolean                 @default(false) @map("overage_enabled")
  periodResetAt          DateTime                @default(dbgenerated("(now() + '30 days'::interval)")) @map("period_reset_at") @db.Timestamptz(6)
  subscriptionExpiresAt  DateTime?               @map("subscription_expires_at") @db.Timestamptz(6)
  maxTelegramButtons    Int?                    @map("max_telegram_buttons") @db.SmallInt // Protocol-level override for max inline buttons (null = use global default)
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiKeys                ApiKey[]
  audit_log              audit_log[]
  digestQueue            DigestQueue[]
  dkimKeys               DkimKey[]
  helioEvents            HelioWebhookEvent[]
  notifications          Notification[]
  payments               Payment[]
  protocol_settings      protocol_settings?
  subscription           Subscription?
  team_members           team_members[]
  webhooks               Webhook[]
  bimi_records           BimiRecord[]
  bimi_verification_logs bimi_verification_log[]
  notificationTemplates  NotificationTemplate[]
  telegramTemplates      TelegramTemplate[]
  protocolAssets       ProtocolAsset[]

  @@index([protocolPubkey], map: "idx_protocols_pubkey")
  @@map("protocols")
}

model ApiKey {
  id                  String    @id @default(uuid()) @db.Uuid
  protocolId          String    @map("protocol_id") @db.Uuid
  keyHash             String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix           String    @map("key_prefix") @db.VarChar(20)
  environment         String    @db.VarChar(10)
  scopes              String[]  @default(["notify:write", "notify:read"])
  name                String?   @db.VarChar(100)
  lastUsedAt          DateTime? @map("last_used_at") @db.Timestamptz(6)
  isRevoked           Boolean   @default(false) @map("is_revoked")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt           DateTime?  @map("expires_at") @db.Timestamptz(6)
  isTestKey           Boolean   @default(false) @map("is_test_key")
  testDailyLimit      Int       @default(100) @map("test_daily_limit") @db.SmallInt
  testNotificationsSent Int     @default(0) @map("test_notifications_sent") @db.SmallInt
  testKeyType         String?   @map("test_key_type") @db.VarChar(20)
  testKeyIpHash       String?   @map("test_key_ip_hash") @db.VarChar(64)
  protocol            Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([keyHash], map: "idx_api_keys_hash")
  @@index([isTestKey, createdAt], map: "idx_api_keys_test_key")
  @@map("api_keys")
}

model Notification {
  id                String            @id @db.Uuid
  protocolId        String            @map("protocol_id") @db.Uuid
  walletHash        String            @map("wallet_hash") @db.VarChar(64)
  status            String            @default("queued") @db.VarChar(20)
  category          String            @default("defi") @db.VarChar(20)
  subjectHash       String            @map("subject_hash") @db.VarChar(64)
  idempotencyKey    String?           @unique @map("idempotency_key") @db.VarChar(128)
  writeReceipt      Boolean           @default(true) @map("write_receipt")
  queuedAt          DateTime          @default(now()) @map("queued_at") @db.Timestamptz(6)
  processingAt      DateTime?         @map("processing_at") @db.Timestamptz(6)
  deliveredAt       DateTime?         @map("delivered_at") @db.Timestamptz(6)
  receiptTx         String?           @map("receipt_tx") @db.VarChar(88)
  sesMessageId      String?           @map("ses_message_id") @db.VarChar(100)
  emailProvider     String?           @map("email_provider") @db.VarChar(20)
  bounce            Boolean           @default(false)
  bounceType        String?           @map("bounce_type") @db.VarChar(10)
  errorCode         String?           @map("error_code") @db.VarChar(80)
  retryCount        Int               @default(0) @map("retry_count") @db.SmallInt
  arweaveId         String?           @map("arweave_id") @db.VarChar(100)
  channelDeliveries ChannelDelivery[]
  emailBounces      EmailBounce[]
  emailDeliveries   EmailDelivery[]
  emailSuppressions EmailSuppression[]
  protocol          Protocol          @relation(fields: [protocolId], references: [id])
  webhookDeliveries WebhookDelivery[]

  @@index([protocolId, queuedAt(sort: Desc)], map: "idx_notifications_protocol")
  @@index([walletHash], map: "idx_notifications_wallet")
  @@index([status], map: "idx_notifications_status")
  @@index([idempotencyKey], map: "idx_notifications_idem")
  @@map("notifications")
}

model ChannelDelivery {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  channel        String       @db.VarChar(20) // 'email', 'telegram', 'sms'
  success        Boolean      @default(false)
  messageId      String?      @map("message_id") @db.VarChar(200)
  provider       String?      @db.VarChar(30)
  error          String?
  deliveredAt    DateTime?    @map("delivered_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId], map: "idx_channel_del_notification")
  @@index([channel, success], map: "idx_channel_del_channel")
  @@map("channel_deliveries")
}

model Webhook {
  id            String            @id @default(uuid()) @db.Uuid
  protocolId    String            @map("protocol_id") @db.Uuid
  url           String
  events        String[]          @default(["notification.delivered"])
  secretHash    String            @map("secret_hash") @db.VarChar(64)
  secretPrefix  String?           @map("secret_prefix") @db.VarChar(10)
  isActive      Boolean           @default(true) @map("is_active")
  failureCount  Int               @default(0) @map("failure_count") @db.SmallInt
  lastSuccessAt DateTime?         @map("last_success_at") @db.Timestamptz(6)
  lastFailureAt DateTime?         @map("last_failure_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  deliveries    WebhookDelivery[]
  protocol      Protocol          @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

model WebhookDelivery {
  id             String        @id @default(uuid()) @db.Uuid
  webhookId      String        @map("webhook_id") @db.Uuid
  notificationId String?       @map("notification_id") @db.Uuid
  event          String        @db.VarChar(40)
  httpStatus     Int?          @map("http_status") @db.SmallInt
  latencyMs      Int?          @map("latency_ms")
  attempt        Int           @default(1) @db.SmallInt
  success        Boolean       @default(false)
  error          String?
  attemptedAt    DateTime      @default(now()) @map("attempted_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])
  webhook        Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, attemptedAt(sort: Desc)], map: "idx_webhook_del_webhook")
  @@map("webhook_deliveries")
}

model DkimKey {
  id          String    @id @default(uuid()) @db.Uuid
  protocolId  String?   @map("protocol_id") @db.Uuid
  domain      String    @db.VarChar(255)
  selector    String    @db.VarChar(63)
  publicKey   String    @map("public_key")
  kmsKeyId    String    @map("kms_key_id") @db.VarChar(255)
  dnsVerified Boolean   @default(false) @map("dns_verified")
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz(6)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol    Protocol? @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([domain, selector])
  @@map("dkim_keys")
}

model EmailSuppression {
  walletHash     String       @id @map("wallet_hash") @db.VarChar(64)
  reason         String       @map("reason") @db.VarChar(20)
  suppressedAt   DateTime     @default(now()) @map("suppressed_at") @db.Timestamptz(6)
  notificationId String?      @map("notification_id") @db.Uuid
  autoSuppressed Boolean      @default(true) @map("auto_suppressed")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])

  @@map("email_suppressions")
}

model EmailBounce {
  id             String        @id @default(uuid()) @db.Uuid
  notificationId String?       @map("notification_id") @db.Uuid
  walletHash     String?       @map("wallet_hash") @db.VarChar(64)
  bounceType     String        @map("bounce_type") @db.VarChar(10)
  sesMessageId   String?       @map("ses_message_id") @db.VarChar(100)
  diagnosticCode String?       @map("diagnostic_code")
  bouncedAt      DateTime      @default(now()) @map("bounced_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])

  @@map("email_bounces")
}

model EmailDelivery {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String?      @map("notification_id") @db.Uuid
  sesMessageId   String?      @map("ses_message_id") @db.VarChar(100)
  smtpResponse   String?      @map("smtp_response")
  processingTime Int?         @map("processing_time_ms")
  deliveredAt    DateTime     @default(now()) @map("delivered_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])

  @@index([sesMessageId], map: "idx_email_delivery_ses_id")
  @@map("email_deliveries")
}

model DigestQueue {
  id            String    @id @default(uuid()) @db.Uuid
  walletHash    String    @map("wallet_hash") @db.VarChar(64)
  protocolId    String    @map("protocol_id") @db.Uuid
  subject       String
  bodyArweaveId String?   @map("body_arweave_id") @db.VarChar(100)
  category      String    @db.VarChar(20)
  queuedAt      DateTime  @default(now()) @map("queued_at") @db.Timestamptz(6)
  scheduledFor  DateTime  @map("scheduled_for") @db.Timestamptz(6)
  sentAt        DateTime? @map("sent_at") @db.Timestamptz(6)
  protocol      Protocol  @relation(fields: [protocolId], references: [id])

  @@unique([walletHash, protocolId, queuedAt])
  @@map("digest_queue")
}

model Subscription {
  id                  String    @id @default(uuid()) @db.Uuid
  protocolId          String    @unique @map("protocol_id") @db.Uuid
  tier                Int       @default(0) @db.SmallInt
  status              String    @default("inactive") @db.VarChar(20)
  helioSubscriptionId String?   @unique @map("helio_subscription_id") @db.VarChar(100)
  helioCustomerId     String?   @map("helio_customer_id") @db.VarChar(100)
  currentPeriodStart  DateTime? @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd    DateTime? @map("current_period_end") @db.Timestamptz(6)
  sendsThisPeriod     BigInt    @default(0) @map("sends_this_period")
  periodResetAt       DateTime  @default(dbgenerated("(now() + '30 days'::interval)")) @map("period_reset_at") @db.Timestamptz(6)
  cancelAtPeriodEnd   Boolean   @default(false) @map("cancel_at_period_end")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol            Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_subscriptions_status")
  @@index([currentPeriodEnd], map: "idx_subscriptions_expiry")
  @@map("subscriptions")
}

model Payment {
  id                 String   @id @default(uuid()) @db.Uuid
  protocolId         String   @map("protocol_id") @db.Uuid
  amountUsdc         BigInt   @map("amount_usdc")
  tokenSymbol        String   @default("USDC") @map("token_symbol") @db.VarChar(10)
  tokenMint          String?  @map("token_mint") @db.VarChar(44)
  paymentSource      String   @map("payment_source") @db.VarChar(30)
  helioTransactionId String?  @unique @map("helio_transaction_id") @db.VarChar(100)
  solanaTxSignature  String?  @map("solana_tx_signature") @db.VarChar(88)
  periodsPaid        Int      @default(1) @map("periods_paid") @db.SmallInt
  periodStart        DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd          DateTime @map("period_end") @db.Timestamptz(6)
  status             String   @default("completed") @db.VarChar(20)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol           Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, createdAt(sort: Desc)], map: "idx_payments_protocol")
  @@map("payments")
}

model HelioWebhookEvent {
  id           String    @id @default(uuid()) @db.Uuid
  helioEventId String    @unique @map("helio_event_id") @db.VarChar(100)
  eventType    String    @map("event_type") @db.VarChar(50)
  protocolId   String?   @map("protocol_id") @db.Uuid
  payloadHash  String    @map("payload_hash") @db.VarChar(64)
  processed    Boolean   @default(false)
  processedAt  DateTime? @map("processed_at") @db.Timestamptz(6)
  error        String?
  receivedAt   DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  protocol     Protocol? @relation(fields: [protocolId], references: [id])

  @@index([eventType, receivedAt(sort: Desc)], map: "idx_helio_events_type")
  @@map("helio_webhook_events")
}

model audit_log {
  id            String        @id @db.Uuid
  protocol_id   String?       @db.Uuid
  actor_id      String?       @db.Uuid
  actor_role    String?       @db.VarChar(20)
  action        String        @db.VarChar(80)
  resource_type String?       @db.VarChar(40)
  resource_id   String?       @db.VarChar(100)
  old_value     Json?
  new_value     Json?
  ip_hash       String?       @db.VarChar(64)
  user_agent    String?
  timestamp     DateTime      @default(now()) @db.Timestamptz(6)
  team_members  team_members? @relation(fields: [actor_id], references: [id])
  protocols     Protocol?     @relation(fields: [protocol_id], references: [id])

  @@index([action, timestamp(sort: Desc)])
  @@index([actor_id, timestamp(sort: Desc)])
  @@index([protocol_id, timestamp(sort: Desc)])
}

model portal_sessions {
  id           String       @id @db.Uuid
  wallet_hash  String       @db.VarChar(64)
  jwt_jti      String       @unique @db.VarChar(36)
  expires_at   DateTime     @db.Timestamptz(6)
  revoked      Boolean      @default(false)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  portal_users portal_users @relation(fields: [wallet_hash], references: [wallet_hash], onDelete: Cascade)

  @@index([wallet_hash])
}

model portal_users {
  wallet_hash        String               @id @db.VarChar(64)
  email_hash         String?              @db.VarChar(64)
  opt_in_all         Boolean              @default(true)
  opt_in_defi        Boolean              @default(true)
  opt_in_governance  Boolean              @default(true)
  opt_in_marketing   Boolean              @default(false)
  digest_mode        Boolean              @default(false)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  portal_sessions    portal_sessions[]
  unsubscribe_tokens unsubscribe_tokens[]
}

model protocol_settings {
  protocol_id             String    @id @db.Uuid
  admin_email_hash        String?   @db.VarChar(64)
  admin_email_encrypted   Bytes?
  website_url             String?
  logo_url                String?
  logo_verified_at        DateTime? @map("logo_verified_at") @db.Timestamptz(6)
  bimi_enabled            Boolean   @default(false) @map("bimi_enabled")
  notification_categories String[]  @default(["defi", "governance", "system"])
  custom_from_name        String?   @db.VarChar(100)
  helio_subscription_id   String?   @db.VarChar(100)
  helio_customer_id       String?   @db.VarChar(100)
  test_email              String?   @db.VarChar(100)
  test_telegram_id        String?   @db.VarChar(100)
  test_phone               String?   @db.VarChar(30)
  updated_at              DateTime  @db.Timestamptz(6)
  protocols               Protocol  @relation(fields: [protocol_id], references: [id], onDelete: Cascade)
}

model team_members {
  id                 String         @id @db.Uuid
  protocol_id        String         @db.Uuid
  email_hash         String         @db.VarChar(64)
  email_encrypted    Bytes?
  role               String         @default("developer") @db.VarChar(20)
  wallet_pubkey      String?        @db.VarChar(44)
  name_encrypted     Bytes?
  is_active          Boolean        @default(true)
  last_login_at      DateTime?      @db.Timestamptz(6)
  invited_by         String?        @db.Uuid
  invite_token       String?        @unique @db.VarChar(100)
  invite_expires_at  DateTime?      @db.Timestamptz(6)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  password_hash      String?        @db.VarChar(100)
  totp_enabled       Boolean        @default(false)
  totp_secret        String?        @db.VarChar(64)
  audit_log          audit_log[]
  team_members       team_members?  @relation("team_membersToteam_members", fields: [invited_by], references: [id])
  other_team_members team_members[] @relation("team_membersToteam_members")
  protocols          Protocol       @relation(fields: [protocol_id], references: [id], onDelete: Cascade)

  @@index([email_hash])
  @@index([protocol_id])
  @@index([wallet_pubkey])
}

model unsubscribe_tokens {
  token_hash   String       @id @db.VarChar(64)
  wallet_hash  String       @db.VarChar(64)
  category     String?      @db.VarChar(20)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  used_at      DateTime?    @db.Timestamptz(6)
  expires_at   DateTime     @default(dbgenerated("(now() + '7 days'::interval)")) @db.Timestamptz(6)
  portal_users portal_users @relation(fields: [wallet_hash], references: [wallet_hash], onDelete: Cascade)

  @@index([expires_at])
}

model BimiRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  protocolId         String   @map("protocol_id") @db.Uuid
  domain             String   @db.VarChar(255)
  selector           String   @default("default") @db.VarChar(63)
  logoUrl            String   @map("logo_url")
  vmcUrl             String?  @map("vmc_url")
  isVerified         Boolean  @default(false) @map("is_verified")
  dmarcVerified      Boolean  @default(false) @map("dmarc_verified")
  dnsRecordPublished Boolean  @default(false) @map("dns_record_published")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol           Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([protocolId, domain])
  @@map("bimi_records")
}

model bimi_verification_log {
  id         String   @id @default(uuid()) @db.Uuid
  protocolId String   @map("protocol_id") @db.Uuid
  domain     String   @db.VarChar(255)
  checkType  String   @db.VarChar(20) // 'dmarc', 'dns', 'logo'
  status     String   @db.VarChar(20) // 'pass', 'fail'
  details    Json?
  checkedAt  DateTime @default(now()) @db.Timestamptz(6)
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@map("bimi_verification_logs")
}

/// Custom email templates stored per protocol (Growth+ tier).
model NotificationTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  protocolId      String   @map("protocol_id") @db.Uuid
  name            String   @db.VarChar(100)
  category        String   @db.VarChar(20)
  subjectTemplate String?  @map("subject_template")
  htmlSource      String?  @map("html_source")
  textSource      String?  @map("text_source")
  previewText     String?  @map("preview_text") @db.VarChar(200)
  heraldFooter    String   @default("full") @map("herald_footer") @db.VarChar(20) // full|small|minimal|none|enterprise
  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")
  version         Int      @default(1) @map("version")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol        Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  versions        NotificationTemplateVersion[]

  @@index([protocolId, category], map: "idx_notif_templates_protocol")
  @@map("notification_templates")
}

/// Version history for email templates (keeps last 10 versions).
model NotificationTemplateVersion {
  id              String   @id @default(uuid()) @db.Uuid
  templateId      String   @map("template_id") @db.Uuid
  version         Int      @default(1) @map("version")
  htmlSource      String   @map("html_source")
  subjectTemplate String?  @map("subject_template")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  template        NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version], map: "idx_template_version")
  @@index([templateId], map: "idx_template_versions_template")
  @@map("notification_template_versions")
}

model TelegramTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  protocolId   String   @map("protocol_id") @db.Uuid
  name         String   @db.VarChar(100)
  category     String   @db.VarChar(20)
  textTemplate String   @map("text_template")
  buttons      Json? // [{label, urlTemplate}]
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol     Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, category], map: "idx_telegram_templates_protocol")
  @@map("telegram_templates")
}

model ProtocolAsset {
  id          String   @id @default(uuid()) @db.Uuid
  protocolId  String   @map("protocol_id") @db.Uuid
  assetType   String   @db.VarChar(20) // "banner" | "video" | "logo"
  url        String   @db.VarChar(500)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([protocolId, assetType])
  @@index([protocolId], map: "idx_protocol_assets_protocol")
  @@map("protocol_assets")
}

model SandboxReceipt {
  id              String    @id @default(uuid()) @db.Uuid
  apiKeyId        String    @map("api_key_id") @db.Uuid
  notificationId String?   @map("notification_id") @db.Uuid
  walletHash     String    @map("wallet_hash") @db.VarChar(64)
  subject         String?   @db.VarChar(200)
  status          String    @default("delivered") @db.VarChar(20)
  devnetTx        String?   @map("devnet_tx") @db.VarChar(88)
  channel         String?   @db.VarChar(20)
  deliveredAt     DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([apiKeyId, createdAt(sort: Desc)], map: "idx_sandbox_receipts_api_key")
  @@index([createdAt], map: "idx_sandbox_receipts_created")
  @@map("sandbox_receipts")
}
