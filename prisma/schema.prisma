generator client {
  provider = "prisma-client-js"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TemplateStatus {
  DRAFT
  APPROVED
  PENDING_REVIEW
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  FLAGGED
}

enum ModerationItemType {
  protocol_registration
  content_scan
  health_degradation
  user_report
}

enum ModerationSeverity {
  low
  medium
  high
  critical
}

model Protocol {
  id                     String                   @id @default(uuid()) @db.Uuid
  protocolPubkey         String                   @unique @map("protocol_pubkey") @db.VarChar(44)
  nameEncrypted          Bytes                    @map("name_encrypted")
  adminNotes             String?                  @map("admin_notes") // Phase 2 — internal only, never exposed to protocol
  tier                   Int                      @default(0) @db.SmallInt
  verificationStatus     VerificationStatus       @default(UNVERIFIED) @map("verification_status")
  strikeCount            Int                      @default(0) @map("strike_count") @db.SmallInt
  strikesResetAt         DateTime?                @map("strikes_reset_at") @db.Timestamptz(6)
  lastStrikeAt           DateTime?                @map("last_strike_at") @db.Timestamptz(6)
  isActive               Boolean                  @default(true) @map("is_active")
  isSuspended            Boolean                  @default(false) @map("is_suspended")
  sendsThisPeriod        BigInt                   @default(0) @map("sends_this_period")
  overageEnabled         Boolean                  @default(false) @map("overage_enabled")
  periodResetAt          DateTime                 @default(dbgenerated("(now() + '30 days'::interval)")) @map("period_reset_at") @db.Timestamptz(6)
  subscriptionExpiresAt  DateTime?                @map("subscription_expires_at") @db.Timestamptz(6)
  maxTelegramButtons    Int?                     @map("max_telegram_buttons") @db.SmallInt
  strikeReasons          Json?                    @map("strike_reasons")
  registrationFlags      Json?                    @map("registration_flags")
  deletedAt              DateTime?                @map("deleted_at") @db.Timestamptz(6)
  verifiedAt             DateTime?                @map("verified_at") @db.Timestamptz(6)
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  bimi_records           bimi_records[]
  bimi_verification_logs bimi_verification_logs[]
  digestQueue            DigestQueue[]
  dkimKeys               DkimKey[]
  helioEvents            HelioWebhookEvent[]
  notifications          Notification[]
  payments               Payment[]
  settings               ProtocolSettings?
  subscription           Subscription?
  teamMembers            TeamMember[]
  webhooks               Webhook[]
  overageLedger          OverageLedger[]
  overageInvoices        OverageInvoice[]
  protocolAssets         ProtocolAsset[]
  notificationTemplates  NotificationTemplate[]
  telegramTemplates      TelegramTemplate[]
  designPartner          DesignPartner? // Phase 3
  apiRequestLogs         ApiRequestLog[]
  engagements            NotificationEngagement[]
  protocolSubscriptions  ProtocolSubscription[]
  audiences              Audience[]
  campaigns              Campaign[]
  scheduledNotifications ScheduledNotification[]
  moderationItems        ModerationQueue[]
  notificationReports    NotificationReport[]
  userPreferences        UserProtocolPreference[]

  @@index([protocolPubkey], map: "idx_protocols_pubkey")
  @@map("protocols")
}

model ApiKey {
  id                    String    @id @default(uuid()) @db.Uuid
  protocolId            String    @map("protocol_id") @db.Uuid
  keyHash               String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix             String    @map("key_prefix") @db.VarChar(20)
  environment           String    @db.VarChar(10)
  scopes                String[]  @default(["notify:write", "notify:read"])
  name                  String?   @db.VarChar(100)
  lastUsedAt            DateTime? @map("last_used_at") @db.Timestamptz(6)
  isRevoked             Boolean   @default(false) @map("is_revoked")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt             DateTime? @map("expires_at") @db.Timestamptz(6)
  isTestKey             Boolean   @default(false) @map("is_test_key")
  testDailyLimit        Int       @default(100) @map("test_daily_limit") @db.SmallInt
  testNotificationsSent Int       @default(0) @map("test_notifications_sent") @db.SmallInt
  testKeyType           String?   @map("test_key_type") @db.VarChar(20)
  testKeyIpHash         String?   @map("test_key_ip_hash") @db.VarChar(64)
  protocol              Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([keyHash], map: "idx_api_keys_hash")
  @@index([isTestKey, createdAt], map: "idx_api_keys_test_key")
  @@map("api_keys")
}

model Notification {
  id                String            @id @db.Uuid
  protocolId        String            @map("protocol_id") @db.Uuid
  walletHash        String            @map("wallet_hash") @db.VarChar(64)
  status            String            @default("queued") @db.VarChar(20)
  category          String            @default("defi") @db.VarChar(20)
  subjectHash       String            @map("subject_hash") @db.VarChar(64)
  idempotencyKey    String?           @unique @map("idempotency_key") @db.VarChar(128)
  writeReceipt      Boolean           @default(true) @map("write_receipt")
  queuedAt          DateTime          @default(now()) @map("queued_at") @db.Timestamptz(6)
  processingAt      DateTime?         @map("processing_at") @db.Timestamptz(6)
  deliveredAt       DateTime?         @map("delivered_at") @db.Timestamptz(6)
  receiptTx              String?           @map("receipt_tx") @db.VarChar(88)
  receiptFailureReason   String?           @map("receipt_failure_reason") // Phase 2
  lastReceiptAttemptAt   DateTime?         @map("last_receipt_attempt_at") @db.Timestamptz(6) // Phase 2
  sesMessageId           String?           @map("ses_message_id") @db.VarChar(100)
  emailProvider     String?           @map("email_provider") @db.VarChar(20)
  bounce            Boolean           @default(false)
  bounceType        String?           @map("bounce_type") @db.VarChar(10)
  errorCode         String?           @map("error_code") @db.VarChar(80)
  retryCount        Int               @default(0) @map("retry_count") @db.SmallInt
  arweaveId         String?           @map("arweave_id") @db.VarChar(100)
  ciphertext        String?           @map("ciphertext") @db.Text
  nonce             String?           @map("nonce") @db.VarChar(48)
  riskScore         Int?              @default(0) @map("risk_score") @db.SmallInt
  scanVerdict       String?           @map("scan_verdict") @db.VarChar(20)
  trackingEnabled   Boolean           @default(false) @map("tracking_enabled")
  emailBounces      EmailBounce[]
  emailSuppressions EmailSuppression[]
  emailDeliveries   EmailDelivery[]
  protocol          Protocol          @relation(fields: [protocolId], references: [id])
  webhookDeliveries WebhookDelivery[]
  channelDeliveries ChannelDelivery[]
  engagements       NotificationEngagement[]

  @@index([protocolId, queuedAt(sort: Desc)], map: "idx_notifications_protocol")
  @@index([walletHash], map: "idx_notifications_wallet")
  @@index([status], map: "idx_notifications_status")
  @@index([idempotencyKey], map: "idx_notifications_idem")
  @@map("notifications")
}

model NotificationEngagement {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String   @map("notification_id") @db.Uuid
  protocolId     String   @map("protocol_id") @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(20)
  linkUrl        String?  @map("link_url") @db.VarChar(2000)
  userAgentHash  String?  @map("user_agent_hash") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  protocol     Protocol     @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, eventType, createdAt(sort: Desc)], map: "idx_engagement_protocol_type")
  @@index([notificationId], map: "idx_engagement_notification")
  @@map("notification_engagements")
}

model Webhook {
  id            String            @id @default(uuid()) @db.Uuid
  protocolId    String            @map("protocol_id") @db.Uuid
  url           String
  events        String[]          @default(["notification.delivered"])
  secretHash    String            @map("secret_hash") @db.VarChar(64)
  secretPrefix  String?           @map("secret_prefix") @db.VarChar(10)
  isActive      Boolean           @default(true) @map("is_active")
  failureCount  Int               @default(0) @map("failure_count") @db.SmallInt
  lastSuccessAt DateTime?         @map("last_success_at") @db.Timestamptz(6)
  lastFailureAt DateTime?         @map("last_failure_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  deliveries    WebhookDelivery[]
  protocol      Protocol          @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

model WebhookDelivery {
  id             String        @id @default(uuid()) @db.Uuid
  webhookId      String        @map("webhook_id") @db.Uuid
  notificationId String?       @map("notification_id") @db.Uuid
  event          String        @db.VarChar(40)
  httpStatus     Int?          @map("http_status") @db.SmallInt
  latencyMs      Int?          @map("latency_ms")
  attempt        Int           @default(1) @db.SmallInt
  success        Boolean       @default(false)
  error          String?
  attemptedAt    DateTime      @default(now()) @map("attempted_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])
  webhook        Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, attemptedAt(sort: Desc)], map: "idx_webhook_del_webhook")
  @@map("webhook_deliveries")
}

model DkimKey {
  id               String    @id @default(uuid()) @db.Uuid
  protocolId       String?   @map("protocol_id") @db.Uuid
  domain           String    @db.VarChar(255)
  selector         String    @db.VarChar(63)
  publicKey        String    @map("public_key")
  kmsKeyId         String    @map("kms_key_id") @db.VarChar(255)
  dnsVerified      Boolean   @default(false) @map("dns_verified")
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz(6)
  isActive         Boolean   @default(true) @map("is_active")
  // Provider registration
  sesVerified      Boolean   @default(false) @map("ses_verified")
  sesCnameRecords  Json?     @map("ses_cname_records")
  resendDomainId   String?   @map("resend_domain_id") @db.VarChar(255)
  resendVerified   Boolean   @default(false) @map("resend_verified")
  resendDnsRecords Json?     @map("resend_dns_records")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol         Protocol? @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([domain, selector])
  @@map("dkim_keys")
}

model EmailSuppression {
  walletHash     String       @id @map("wallet_hash") @db.VarChar(64)
  reason         String       @map("reason") @db.VarChar(20)
  suppressedAt   DateTime     @default(now()) @map("suppressed_at") @db.Timestamptz(6)
  notificationId String?      @map("notification_id") @db.Uuid
  autoSuppressed Boolean      @default(true) @map("auto_suppressed")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])

  @@map("email_suppressions")
}

model EmailBounce {
  id             String        @id @default(uuid()) @db.Uuid
  notificationId String?       @map("notification_id") @db.Uuid
  walletHash     String?       @map("wallet_hash") @db.VarChar(64)
  bounceType     String        @map("bounce_type") @db.VarChar(10)
  sesMessageId   String?       @map("ses_message_id") @db.VarChar(100)
  diagnosticCode String?       @map("diagnostic_code")
  bouncedAt      DateTime      @default(now()) @map("bounced_at") @db.Timestamptz(6)
  notification   Notification? @relation(fields: [notificationId], references: [id])

  @@map("email_bounces")
}

model EmailDelivery {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String      @map("notification_id") @db.Uuid
  sesMessageId   String?      @map("ses_message_id") @db.VarChar(100)
  smtpResponse   String?      @map("smtp_response")
  processingTime Int?         @map("processing_time_ms")
  deliveredAt    DateTime     @default(now()) @map("delivered_at") @db.Timestamptz(6)
  notification   Notification @relation(fields: [notificationId], references: [id])

  @@index([sesMessageId], map: "idx_email_delivery_ses_id")
  @@map("email_deliveries")
}

model DigestQueue {
  id            String    @id @default(uuid()) @db.Uuid
  walletHash    String    @map("wallet_hash") @db.VarChar(64)
  protocolId    String    @map("protocol_id") @db.Uuid
  subject       String
  bodyArweaveId String?   @map("body_arweave_id") @db.VarChar(100)
  category      String    @db.VarChar(20)
  queuedAt      DateTime  @default(now()) @map("queued_at") @db.Timestamptz(6)
  scheduledFor  DateTime  @map("scheduled_for") @db.Timestamptz(6)
  sentAt        DateTime? @map("sent_at") @db.Timestamptz(6)
  protocol      Protocol  @relation(fields: [protocolId], references: [id])

  @@unique([walletHash, protocolId, queuedAt])
  @@map("digest_queue")
}

model Subscription {
  id                  String    @id @default(uuid()) @db.Uuid
  protocolId          String    @unique @map("protocol_id") @db.Uuid
  tier                Int       @default(0) @db.SmallInt
  status              String    @default("inactive") @db.VarChar(20)
  helioSubscriptionId String?   @unique @map("helio_subscription_id") @db.VarChar(100)
  helioCustomerId     String?   @map("helio_customer_id") @db.VarChar(100)
  currentPeriodStart  DateTime? @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd    DateTime? @map("current_period_end") @db.Timestamptz(6)
  sendsThisPeriod     BigInt    @default(0) @map("sends_this_period")
  periodResetAt       DateTime  @default(dbgenerated("(now() + '30 days'::interval)")) @map("period_reset_at") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  gracePeriodDays      Int       @default(3) @map("grace_period_days")
  gracePeriodStartedAt DateTime? @map("grace_period_started_at") @db.Timestamptz(6)
  gracePeriodEndsAt    DateTime? @map("grace_period_ends_at") @db.Timestamptz(6)
  renewalDueDate       DateTime? @map("renewal_due_date") @db.Timestamptz(6)
  lastReminderSent     DateTime? @map("last_reminder_sent") @db.Timestamptz(6)
  nextChargeUrl        String?   @map("next_charge_url")
  chargeToken          String?   @map("charge_token")
  endedAt              DateTime? @map("ended_at") @db.Timestamptz(6)
  endReason            String?   @map("end_reason")
  isAnonymous          Boolean   @default(false) @map("is_anonymous")
  overagesThisPeriod    BigInt    @default(0) @map("overages_this_period")
  overageUsdcThisPeriod BigInt    @default(0) @map("overage_usdc_this_period")
  overageHardCapHit     Boolean   @default(false) @map("overage_hard_cap_hit")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol            Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_subscriptions_status")
  @@index([currentPeriodEnd], map: "idx_subscriptions_expiry")
  @@map("subscriptions")
}

model Payment {
  id                 String   @id @default(uuid()) @db.Uuid
  protocolId         String   @map("protocol_id") @db.Uuid
  amountUsdc         BigInt   @map("amount_usdc")
  tokenSymbol        String   @default("USDC") @map("token_symbol") @db.VarChar(10)
  tokenMint          String?  @map("token_mint") @db.VarChar(44)
  paymentSource      String   @map("payment_source") @db.VarChar(30)
  helioTransactionId String?  @unique @map("helio_transaction_id") @db.VarChar(100)
  solanaTxSignature  String?  @map("solana_tx_signature") @db.VarChar(88)
  periodsPaid        Int      @default(1) @map("periods_paid") @db.SmallInt
  periodStart        DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd          DateTime @map("period_end") @db.Timestamptz(6)
  status             String   @default("completed") @db.VarChar(20)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol           Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, createdAt(sort: Desc)], map: "idx_payments_protocol")
  @@map("payments")
}

model HelioWebhookEvent {
  id           String    @id @default(uuid()) @db.Uuid
  helioEventId String    @unique @map("helio_event_id") @db.VarChar(100)
  eventType    String    @map("event_type") @db.VarChar(50)
  protocolId   String?   @map("protocol_id") @db.Uuid
  payloadHash  String    @map("payload_hash") @db.VarChar(64)
  processed    Boolean   @default(false)
  processedAt  DateTime? @map("processed_at") @db.Timestamptz(6)
  error        String?
  receivedAt   DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  protocol     Protocol? @relation(fields: [protocolId], references: [id])

  @@index([eventType, receivedAt(sort: Desc)], map: "idx_helio_events_type")
  @@map("helio_webhook_events")
}

model ProtocolSettings {
  protocolId             String    @id @map("protocol_id") @db.Uuid
  adminEmailHash         String?   @map("admin_email_hash") @db.VarChar(64)
  adminEmailEncrypted    Bytes?    @map("admin_email_encrypted")
  websiteUrl             String?   @map("website_url")
  logoUrl                String?   @map("logo_url")
  notificationCategories String[]  @default(["defi", "governance", "system"]) @map("notification_categories")
  customFromName         String?   @map("custom_from_name") @db.VarChar(100)
  helioSubscriptionId    String?   @map("helio_subscription_id") @db.VarChar(100)
  helioCustomerId        String?   @map("helio_customer_id") @db.VarChar(100)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  bimi_enabled           Boolean   @default(false)
  logo_verified_at       DateTime? @db.Timestamptz(6)
  optInOverage           Boolean   @default(false) @map("opt_in_overage")
  maxOverageUsdc         BigInt    @default(500000000) @map("max_overage_usdc")
  overageAlertAtUsdc     BigInt    @default(50000000) @map("overage_alert_at_usdc")
  overageHardCapEnabled  Boolean   @default(true) @map("overage_hard_cap_enabled")
  retryMaxAttempts       Int       @default(3) @map("retry_max_attempts") @db.SmallInt
  retryWindowHours       Int       @default(6) @map("retry_window_hours") @db.SmallInt
  retryBackoff           String    @default("exponential") @map("retry_backoff") @db.VarChar(20)
  criticalCategories        String[]  @default([]) @map("critical_categories")
  trackEngagement           Boolean   @default(false) @map("track_engagement")
  testEmail                 String?   @map("test_email") @db.VarChar(100)
  testTelegramId            String?   @map("test_telegram_id") @db.VarChar(100)
  testPhone                 String?   @map("test_phone") @db.VarChar(30)
  // Telegram custom bot (Growth+, Tier 2+)
  telegramBotTokenEncrypted  Bytes?    @map("telegram_bot_token_encrypted")
  telegramBotUsername        String?   @map("telegram_bot_username") @db.VarChar(64)
  telegramBotName            String?   @map("telegram_bot_name") @db.VarChar(64)
  telegramGroupChatId        String?   @map("telegram_group_chat_id") @db.VarChar(30)
  telegramThreadIds          Json?     @map("telegram_thread_ids")
  telegramAutoPinEnabled     Boolean   @default(false) @map("telegram_auto_pin_enabled")
  telegramWelcomeMessage     String?   @map("telegram_welcome_message") @db.VarChar(500)
  telegramGroupMemberCount   Int?      @map("telegram_group_member_count")
  telegramMemberCountAt      DateTime? @map("telegram_member_count_at") @db.Timestamptz(6)
  telegramMigrationSentAt    DateTime? @map("telegram_migration_sent_at") @db.Timestamptz(6)
  protocol                  Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@map("protocol_settings")
}

// ── telegram_pending_connections ─────────────────────────────────────────────
// Temporary table: Herald bot stores chat_id after /start <wallet_pubkey>.
// The user portal polls for this and includes it in their on-chain identity tx.
// Expires after 10 minutes; auto-cleaned by a cron on the gateway.

model TelegramPendingConnection {
  id               String    @id @default(uuid()) @db.Uuid
  walletPubkey     String    @map("wallet_pubkey") @db.VarChar(44)
  chatId           String    @map("chat_id") @db.VarChar(30)
  telegramUsername String?   @map("telegram_username") @db.VarChar(50)
  claimed          Boolean   @default(false)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([walletPubkey, claimed], map: "idx_tg_pending_wallet")
  @@map("telegram_pending_connections")
}

model TeamMember {
  id              String       @id @default(uuid()) @db.Uuid
  protocolId      String       @map("protocol_id") @db.Uuid
  emailHash       String       @map("email_hash") @db.VarChar(64)
  emailEncrypted  Bytes?       @map("email_encrypted")
  role            String       @default("developer") @db.VarChar(20)
  walletPubkey    String?      @map("wallet_pubkey") @db.VarChar(44)
  nameEncrypted   Bytes?       @map("name_encrypted")
  isActive        Boolean      @default(true) @map("is_active")
  lastLoginAt     DateTime?    @map("last_login_at") @db.Timestamptz(6)
  invitedBy       String?      @map("invited_by") @db.Uuid
  inviteToken     String?      @unique @map("invite_token") @db.VarChar(100)
  inviteExpiresAt DateTime?    @map("invite_expires_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  passwordHash    String?      @map("password_hash") @db.VarChar(100)
  totpEnabled     Boolean      @default(false) @map("totp_enabled")
  totpSecret      String?      @map("totp_secret") @db.VarChar(64)
  auditLogs       AuditLog[]
  inviter         TeamMember?  @relation("TeamMemberInvites", fields: [invitedBy], references: [id])
  invitees        TeamMember[] @relation("TeamMemberInvites")
  protocol        Protocol     @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId])
  @@index([emailHash])
  @@index([walletPubkey])
  @@map("team_members")
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  protocolId   String?     @map("protocol_id") @db.Uuid
  actorId      String?     @map("actor_id") @db.Uuid
  actorRole    String?     @map("actor_role") @db.VarChar(20)
  action       String      @db.VarChar(80)
  resourceType String?     @map("resource_type") @db.VarChar(40)
  resourceId   String?     @map("resource_id") @db.VarChar(100)
  oldValue     Json?       @map("old_value")
  newValue     Json?       @map("new_value")
  ipHash       String?     @map("ip_hash") @db.VarChar(64)
  userAgent    String?     @map("user_agent")
  timestamp    DateTime    @default(now()) @db.Timestamptz(6)
  actor        TeamMember? @relation(fields: [actorId], references: [id])
  protocol     Protocol?   @relation(fields: [protocolId], references: [id])

  @@index([protocolId, timestamp(sort: Desc)])
  @@index([actorId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
  @@map("audit_log")
}

model UnsubscribeToken {
  tokenHash  String     @id @map("token_hash") @db.VarChar(64)
  walletHash String     @map("wallet_hash") @db.VarChar(64)
  category   String?    @db.VarChar(20)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  usedAt     DateTime?  @map("used_at") @db.Timestamptz(6)
  expiresAt  DateTime   @default(dbgenerated("(now() + '7 days'::interval)")) @map("expires_at") @db.Timestamptz(6)
  user       PortalUser @relation(fields: [walletHash], references: [walletHash], onDelete: Cascade)

  @@index([expiresAt])
  @@map("unsubscribe_tokens")
}

model UserProtocolPreference {
  id              String   @id @default(uuid()) @db.Uuid
  walletHash      String   @map("wallet_hash") @db.VarChar(64)
  protocolId      String   @map("protocol_id") @db.Uuid
  // Per-protocol category overrides (null = inherit global setting)
  optInDefi       Boolean? @map("opt_in_defi")
  optInGovernance Boolean? @map("opt_in_governance")
  optInMarketing  Boolean? @map("opt_in_marketing")
  optInSystem     Boolean? @map("opt_in_system")
  // Per-protocol channel override (null = inherit from ProtocolSubscription)
  channels        String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     PortalUser @relation(fields: [walletHash], references: [walletHash], onDelete: Cascade)
  protocol Protocol   @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([walletHash, protocolId])
  @@index([walletHash])
  @@map("user_protocol_preferences")
}

model PortalSession {
  id         String     @id @default(uuid()) @db.Uuid
  walletHash String     @map("wallet_hash") @db.VarChar(64)
  jwtJti     String     @unique @map("jwt_jti") @db.VarChar(36)
  expiresAt  DateTime   @map("expires_at") @db.Timestamptz(6)
  revoked    Boolean    @default(false)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user       PortalUser @relation(fields: [walletHash], references: [walletHash], onDelete: Cascade)

  @@index([walletHash])
  @@map("portal_sessions")
}

model PortalUser {
  walletHash        String             @id @map("wallet_hash") @db.VarChar(64)
  emailHash         String?            @map("email_hash") @db.VarChar(64)
  optInAll          Boolean            @default(true) @map("opt_in_all")
  optInDefi         Boolean            @default(true) @map("opt_in_defi")
  optInGovernance   Boolean            @default(true) @map("opt_in_governance")
  optInMarketing    Boolean            @default(false) @map("opt_in_marketing")
  digestMode        Boolean            @default(false) @map("digest_mode")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions            PortalSession[]
  unsubscribeTokens   UnsubscribeToken[]
  protocolPreferences UserProtocolPreference[]

  @@map("portal_users")
}

model bimi_records {
  id                   String   @id @default(uuid()) @db.Uuid
  protocol_id          String   @db.Uuid
  domain               String   @db.VarChar(255)
  selector             String   @default("default") @db.VarChar(63)
  logo_url             String
  vmc_url              String?
  is_verified          Boolean  @default(false)
  dmarc_verified       Boolean  @default(false)
  dns_record_published Boolean  @default(false)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  protocols            Protocol @relation(fields: [protocol_id], references: [id], onDelete: Cascade)

  @@unique([protocol_id, domain])
}

model bimi_verification_logs {
  id          String   @id @default(uuid()) @db.Uuid
  protocol_id String   @db.Uuid
  domain      String   @db.VarChar(255)
  checkType   String   @map("check_type") @db.VarChar(20)
  status      String   @db.VarChar(20)
  details     Json?
  checkedAt   DateTime @default(now()) @map("checked_at") @db.Timestamptz(6)
  protocols   Protocol @relation(fields: [protocol_id], references: [id], onDelete: Cascade)
}

model OverageLedger {
  id             String          @id @default(uuid()) @db.Uuid
  protocolId     String          @map("protocol_id") @db.Uuid
  notificationId String?         @map("notification_id") @db.Uuid
  channel        String          @default("email") @db.VarChar(20)
  tierAtSend     Int             @map("tier_at_send") @db.SmallInt
  priceUsdc      BigInt          @map("price_usdc")
  periodStart    DateTime        @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime        @map("period_end") @db.Timestamptz(6)
  settled        Boolean         @default(false)
  invoiceId      String?         @map("invoice_id") @db.Uuid
  sentAt         DateTime        @default(now()) @map("sent_at") @db.Timestamptz(6)
  invoice        OverageInvoice? @relation(fields: [invoiceId], references: [id])
  protocol       Protocol        @relation(fields: [protocolId], references: [id])

  @@index([protocolId, periodStart, settled], map: "idx_overage_protocol_period")
  @@map("overage_ledger")
}

model OverageInvoice {
  id                 String          @id @default(uuid()) @db.Uuid
  protocolId         String          @map("protocol_id") @db.Uuid
  periodStart        DateTime        @map("period_start") @db.Timestamptz(6)
  periodEnd          DateTime        @map("period_end") @db.Timestamptz(6)
  totalOverages      BigInt          @map("total_overages")
  totalUsdc          BigInt          @map("total_usdc")
  channelBreakdown   Json            @default("{}") @map("channel_breakdown")
  status             String          @default("pending") @db.VarChar(20)
  collectionMethod   String?         @map("collection_method") @db.VarChar(20)
  helioPaymentLink   String?         @map("helio_payment_link")
  helioTransactionId String?         @unique @map("helio_transaction_id") @db.VarChar(100)
  solanaTxSignature  String?         @map("solana_tx_signature") @db.VarChar(88)
  issuedAt           DateTime        @default(now()) @map("issued_at") @db.Timestamptz(6)
  dueAt              DateTime        @map("due_at") @db.Timestamptz(6)
  paidAt             DateTime?       @map("paid_at") @db.Timestamptz(6)
  failedAt           DateTime?       @map("failed_at") @db.Timestamptz(6)
  failureReason      String?         @map("failure_reason")
  ledgerEntries      OverageLedger[]
  protocol           Protocol        @relation(fields: [protocolId], references: [id])

  @@index([protocolId, periodStart], map: "idx_overage_inv_protocol")
  @@map("overage_invoices")
}

enum MonitorStatus {
  up
  down
  degraded
}

enum IncidentStatus {
  investigating
  identified
  monitoring
  resolved
}

enum IncidentSeverity {
  critical
  major
  minor
  maintenance
}

model Monitor {
  id                  String        @id @default(uuid()) @db.Uuid
  name                String        @db.VarChar(255)
  url                 String        @db.VarChar(255)
  interval            Int           @default(60)
  timeout             Int           @default(5000)
  isActive            Boolean       @default(true) @map("is_active")
  currentStatus       MonitorStatus @default(up) @map("current_status")
  uptimePercentage    Decimal       @default(0) @map("uptime_percentage") @db.Decimal(5, 2)
  averageResponseTime Int           @default(0) @map("average_response_time")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  checks              Check[]
  incidents           Incident[]

  @@map("monitors")
}

model Check {
  id           String        @id @default(uuid()) @db.Uuid
  monitorId    String        @map("monitor_id") @db.Uuid
  status       MonitorStatus
  responseTime Int           @map("response_time")
  statusCode   Int?          @map("status_code")
  errorMessage String?       @map("error_message")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  monitor      Monitor       @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, createdAt], map: "idx_checks_monitor_date")
  @@map("checks")
}

model Incident {
  id                 String              @id @default(uuid()) @db.Uuid
  monitorId          String?             @map("monitor_id") @db.Uuid // Phase 2: made nullable so admin can create incidents without a monitor
  affectedComponent  String?             @map("affected_component") @db.VarChar(255) // Phase 2
  title              String              @db.VarChar(255)
  description        String              @db.Text
  status             IncidentStatus      @default(investigating)
  severity           IncidentSeverity
  startedAt          DateTime?           @map("started_at") @db.Timestamptz(6)
  resolvedAt         DateTime?           @map("resolved_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  monitor            Monitor?            @relation(fields: [monitorId], references: [id], onDelete: SetNull)
  timelines          IncidentTimeline[]  // Phase 2

  @@map("incidents")
}

// Phase 2 — timeline entries for admin-managed incidents
model IncidentTimeline {
  id         String   @id @default(uuid()) @db.Uuid
  incidentId String   @map("incident_id") @db.Uuid
  message    String
  author     String   @default("herald-admin") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt], map: "idx_incident_timeline_incident")
  @@map("incident_timelines")
}

model ProtocolAsset {
  id          String    @id @default(uuid()) @db.Uuid
  protocolId  String    @map("protocol_id") @db.Uuid
  assetType   String    @db.VarChar(20) // "banner" | "video" | "logo"
  url        String    @db.VarChar(500)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol   Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([protocolId, assetType])
  @@index([protocolId], map: "idx_protocol_assets_protocol")
  @@map("protocol_assets")
}

/// Custom email templates stored per protocol (Growth+ tier).
model NotificationTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  protocolId      String    @map("protocol_id") @db.Uuid
  name            String    @db.VarChar(100)
  category        String    @db.VarChar(20)
  subjectTemplate String?   @map("subject_template")
  htmlSource      String?   @map("html_source")
  textSource     String?   @map("text_source")
  previewText    String?   @map("preview_text") @db.VarChar(200)
  heraldFooter  String         @default("full") @map("herald_footer") @db.VarChar(20)
  status        TemplateStatus @default(DRAFT)
  isActive       Boolean        @default(true) @map("is_active")
  isDefault     Boolean        @default(false) @map("is_default")
  version       Int            @default(1) @map("version")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol      Protocol       @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  versions      NotificationTemplateVersion[]

  @@index([protocolId, category], map: "idx_notif_templates_protocol")
  @@map("notification_templates")
}

/// Version history for email templates.
model NotificationTemplateVersion {
  id              String   @id @default(uuid()) @db.Uuid
  templateId     String   @map("template_id") @db.Uuid
  version        Int      @default(1) @map("version")
  htmlSource     String   @map("html_source")
  subjectTemplate String? @map("subject_template")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  template       NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version], map: "idx_template_version")
  @@index([templateId], map: "idx_template_versions_template")
  @@map("notification_template_versions")
}

enum AdminUserRole {
  super_admin
  admin
  viewer
}

enum AdminAuthMethod {
  wallet
  email_totp @map("email-totp")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Herald internal admin team (separate from per-protocol TeamMember)
// Roles: super_admin | admin | viewer
// Auth:  wallet | email-totp
// ─────────────────────────────────────────────────────────────────────────────
model AdminUser {
  id               String          @id @default(uuid()) @db.Uuid
  displayName      String          @map("display_name") @db.VarChar(100)
  role             AdminUserRole   @default(viewer)
  authMethod       AdminAuthMethod @map("auth_method")
  walletPubkeyHash String?   @map("wallet_pubkey_hash") @db.VarChar(64)
  emailHash        String?   @map("email_hash") @db.VarChar(64)
  emailEncrypted   Bytes?    @map("email_encrypted")
  passwordHash     String?   @map("password_hash") @db.VarChar(100)
  totpEnabled      Boolean   @default(false) @map("totp_enabled")
  totpSecret       String?   @map("totp_secret") @db.VarChar(64)
  isActive         Boolean   @default(true) @map("is_active")
  lastActiveAt     DateTime? @map("last_active_at") @db.Timestamptz(6)
  invitedBy        String?   @map("invited_by") @db.Uuid
  inviteToken      String?   @unique @map("invite_token") @db.VarChar(100)
  inviteExpiresAt  DateTime? @map("invite_expires_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([walletPubkeyHash], map: "idx_admin_users_wallet")
  @@index([emailHash], map: "idx_admin_users_email")
  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Design partners (protocols with retainer agreements)
// ─────────────────────────────────────────────────────────────────────────────
model DesignPartner {
  id                  String    @id @default(uuid()) @db.Uuid
  protocolId          String    @unique @map("protocol_id") @db.Uuid
  retainerAmountCents Int       @default(100000) @map("retainer_amount_cents")
  retainerStart       DateTime  @map("retainer_start") @db.Timestamptz(6)
  retainerEnd         DateTime? @map("retainer_end") @db.Timestamptz(6)
  status              String    @default("active") @db.VarChar(20)
  feedbackSessions    Int       @default(0) @map("feedback_sessions")
  equityWarrantIssued Boolean   @default(false) @map("equity_warrant_issued")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  protocol            Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_design_partners_status")
  @@map("design_partners")
}

// ── channel_deliveries ──────────────────────────────────────────────────────
// Tracks per-channel delivery outcome for each notification.
model ChannelDelivery {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  channel        String       @db.VarChar(20) // 'email', 'telegram', 'sms'
  success        Boolean      @default(false)
  messageId      String?      @map("message_id") @db.VarChar(200)
  provider       String?      @db.VarChar(30)
  error          String?
  deliveredAt    DateTime?    @map("delivered_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId], map: "idx_channel_del_notification")
  @@index([channel, success], map: "idx_channel_del_channel")
  @@map("channel_deliveries")
}

// ── telegram_templates ──────────────────────────────────────────────────────
// Custom Telegram message templates per protocol.
model TelegramTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  protocolId   String   @map("protocol_id") @db.Uuid
  name         String   @db.VarChar(100)
  category     String   @db.VarChar(20)
  textTemplate String   @map("text_template")
  buttons      Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol     Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, category], map: "idx_telegram_templates_protocol")
  @@map("telegram_templates")
}

// ── sandbox_receipts ────────────────────────────────────────────────────────
// Receipts for sandbox/test API key notifications.
model SandboxReceipt {
  id              String    @id @default(uuid()) @db.Uuid
  apiKeyId        String    @map("api_key_id") @db.Uuid
  notificationId String?   @map("notification_id") @db.Uuid
  walletHash     String    @map("wallet_hash") @db.VarChar(64)
  subject         String?   @db.VarChar(200)
  status          String    @default("delivered") @db.VarChar(20)
  devnetTx        String?   @map("devnet_tx") @db.VarChar(88)
  channel         String?   @db.VarChar(20)
  deliveredAt     DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([apiKeyId, createdAt(sort: Desc)], map: "idx_sandbox_receipts_api_key")
  @@index([createdAt], map: "idx_sandbox_receipts_created")
  @@map("sandbox_receipts")
}

// ── api_request_logs ────────────────────────────────────────────────────────
// Logs every authenticated inbound API request for the Request Inspector.
model ApiRequestLog {
  id            String    @id @default(uuid()) @db.Uuid
  protocolId    String    @map("protocol_id") @db.Uuid
  apiKeyId      String?   @map("api_key_id") @db.Uuid
  isTestKey     Boolean   @default(false) @map("is_test_key")
  method        String    @db.VarChar(10)
  endpoint      String    @db.VarChar(200)
  requestBody   Json?     @map("request_body")
  responseBody  Json?     @map("response_body")
  statusCode    Int       @map("status_code")
  latencyMs     Int       @map("latency_ms")
  correlationId String?   @map("correlation_id") @db.VarChar(128)
  ipHash        String?   @map("ip_hash") @db.VarChar(64)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, createdAt(sort: Desc)], map: "idx_api_request_logs_protocol")
  @@index([correlationId], map: "idx_api_request_logs_correlation")
  @@map("api_request_logs")
}

// Tracks per-protocol opt-in intent — created when a user visits /join/:protocolId
// or clicks "Enable Notifications" in a protocol's embedded SDK button.
// walletPubkey is null for legacy rows backfilled from the notifications table
// (we have the hash but not the original pubkey from old records).
model ProtocolSubscription {
  id           String   @id @default(uuid()) @db.Uuid
  walletPubkey String?  @map("wallet_pubkey") @db.VarChar(44)
  walletHash   String   @map("wallet_hash") @db.VarChar(64)
  protocolId   String   @map("protocol_id") @db.Uuid
  channels     String[] @default(["email"])
  status       String   @default("active") @db.VarChar(20)
  source       String   @default("join_link") @db.VarChar(30)
  subscribedAt DateTime @default(now()) @map("subscribed_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([walletHash, protocolId], map: "protocol_subscriptions_wallet_hash_protocol_id_key")
  @@index([protocolId, status], map: "idx_protocol_subscriptions_protocol_status")
  @@index([walletHash], map: "idx_protocol_subscriptions_wallet")
  @@map("protocol_subscriptions")
}

// ── Campaign Management ──────────────────────────────────────────────────────
// Shared with herald-admin-registration-api — both repos connect to the same DB.

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Audience {
  id          String   @id @default(uuid()) @db.Uuid
  protocolId  String   @map("protocol_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  wallets     String[]
  walletCount Int      @default(0) @map("wallet_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  protocol  Protocol   @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([protocolId], map: "idx_audiences_protocol")
  @@map("audiences")
}

model Campaign {
  id           String         @id @default(uuid()) @db.Uuid
  protocolId   String         @map("protocol_id") @db.Uuid
  audienceId   String         @map("audience_id") @db.Uuid
  templateId   String?        @map("template_id") @db.Uuid
  subject      String         @db.VarChar(200)
  body         String
  category     String         @default("defi") @db.VarChar(30)
  channels     String[]       @default(["email"])
  status       CampaignStatus @default(DRAFT)
  scheduledFor DateTime?      @map("scheduled_for") @db.Timestamptz(6)
  startedAt    DateTime?      @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(6)
  totalTargets Int            @default(0) @map("total_targets")
  totalSent    Int            @default(0) @map("total_sent")
  totalFailed  Int            @default(0) @map("total_failed")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  audience Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  @@index([protocolId, status], map: "idx_campaigns_protocol_status")
  @@map("campaigns")
}

// ── Scheduled Notifications (Feature 8) ─────────────────────────────────────

enum ScheduleType {
  ONE_TIME
  RECURRING
}

enum ScheduledJobStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
  FAILED
}

model ScheduledNotification {
  id           String             @id @default(uuid()) @db.Uuid
  protocolId   String             @map("protocol_id") @db.Uuid
  wallet       String?            @db.VarChar(44)
  subject      String             @db.VarChar(200)
  body         String
  category     String             @default("defi") @db.VarChar(30)
  channels     String[]           @default(["email"])
  scheduleType ScheduleType       @default(ONE_TIME) @map("schedule_type")
  cronExpr     String?            @map("cron_expr") @db.VarChar(100)
  timezone     String             @default("UTC") @db.VarChar(50)
  nextRunAt    DateTime           @map("next_run_at") @db.Timestamptz(6)
  lastRunAt    DateTime?          @map("last_run_at") @db.Timestamptz(6)
  status       ScheduledJobStatus @default(PENDING)
  templateId   String?            @map("template_id") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, status, nextRunAt], map: "idx_scheduled_notifications_protocol")
  @@map("scheduled_notifications")
}

// ── moderation_queue ────────────────────────────────────────────────────────
// Gateway writes content_scan items here; admin-api manages the full queue.
model ModerationQueue {
  id            String             @id @default(uuid()) @db.Uuid
  protocolId    String             @map("protocol_id") @db.Uuid
  type          ModerationItemType
  severity      ModerationSeverity @default(medium)
  flagReason    String             @map("flag_reason") @db.Text
  aiScanResult  Json?              @map("ai_scan_result")
  rulesTriggers String[]           @map("rules_triggers") @default([])
  resolvedAt    DateTime?          @map("resolved_at") @db.Timestamptz(6)
  resolvedBy    String?            @map("resolved_by") @db.VarChar(100)
  resolution    String?            @db.VarChar(30)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  protocol      Protocol           @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId, createdAt(sort: Desc)], map: "idx_modq_protocol")
  @@index([resolvedAt], map: "idx_modq_resolved")
  @@map("moderation_queue")
}

// ── Sprint 5 — End-User Reporting ───────────────────────────────────────────

model NotificationReport {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String   @map("notification_id") @db.Uuid
  protocolId     String   @map("protocol_id") @db.Uuid
  walletHash     String   @map("wallet_hash") @db.VarChar(64)
  reason         String   @db.VarChar(30)
  details        String?  @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([notificationId, walletHash], name: "uq_report_per_wallet")
  @@index([protocolId, createdAt], map: "idx_notification_reports_protocol")
  @@map("notification_reports")
}
