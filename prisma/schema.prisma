// ────────────────────────────────────────────────────────────────────
// Herald Notification Gateway — Prisma Schema
// ────────────────────────────────────────────────────────────────────
// Zero-PII database. Wallets stored as SHA-256 hashes only.
// API keys stored as SHA-256 hashes only.
// Emails NEVER appear in this schema.
// ────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ── Protocols ──────────────────────────────────────────────────────

model Protocol {
  id                    String    @id @default(uuid()) @db.Uuid
  protocolPubkey        String    @unique @map("protocol_pubkey") @db.VarChar(44)
  nameEncrypted         Bytes     @map("name_encrypted")
  tier                  Int       @default(0) @db.SmallInt
  isActive              Boolean   @default(true) @map("is_active")
  isSuspended           Boolean   @default(false) @map("is_suspended")
  sendsThisPeriod       BigInt    @default(0) @map("sends_this_period")
  periodResetAt         DateTime  @default(dbgenerated("NOW() + INTERVAL '30 days'")) @map("period_reset_at") @db.Timestamptz()
  subscriptionExpiresAt DateTime? @map("subscription_expires_at") @db.Timestamptz()
  stripeCustomerId      String?   @map("stripe_customer_id") @db.VarChar(32)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  apiKeys       ApiKey[]
  notifications Notification[]
  webhooks      Webhook[]
  dkimKeys      DkimKey[]
  digestQueue   DigestQueue[]

  @@index([protocolPubkey], name: "idx_protocols_pubkey")
  @@map("protocols")
}

// ── API Keys ───────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  protocolId  String    @map("protocol_id") @db.Uuid
  keyHash     String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix   String    @map("key_prefix") @db.VarChar(20)
  environment String    @db.VarChar(10)
  scopes      String[]  @default(["notify:write"])
  name        String?   @db.VarChar(100)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  isRevoked   Boolean   @default(false) @map("is_revoked")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([keyHash], name: "idx_api_keys_hash")
  @@map("api_keys")
}

// ── Notifications ──────────────────────────────────────────────────

model Notification {
  id             String    @id @db.Uuid
  protocolId     String    @map("protocol_id") @db.Uuid
  walletHash     String    @map("wallet_hash") @db.VarChar(64)
  status         String    @default("queued") @db.VarChar(20)
  category       String    @default("defi") @db.VarChar(20)
  subjectHash    String    @map("subject_hash") @db.VarChar(64)
  idempotencyKey String?   @unique @map("idempotency_key") @db.VarChar(128)
  writeReceipt   Boolean   @default(true) @map("write_receipt")
  queuedAt       DateTime  @default(now()) @map("queued_at") @db.Timestamptz()
  processingAt   DateTime? @map("processing_at") @db.Timestamptz()
  deliveredAt    DateTime? @map("delivered_at") @db.Timestamptz()
  receiptTx      String?   @map("receipt_tx") @db.VarChar(88)
  sesMessageId   String?   @map("ses_message_id") @db.VarChar(100)
  emailProvider  String?   @map("email_provider") @db.VarChar(20)
  bounce         Boolean   @default(false)
  bounceType     String?   @map("bounce_type") @db.VarChar(10)
  errorCode      String?   @map("error_code") @db.VarChar(80)
  retryCount     Int       @default(0) @map("retry_count") @db.SmallInt
  arweaveId      String?   @map("arweave_id") @db.VarChar(100)

  protocol          Protocol          @relation(fields: [protocolId], references: [id])
  emailBounces      EmailBounce[]
  webhookDeliveries WebhookDelivery[]

  @@index([protocolId, queuedAt(sort: Desc)], name: "idx_notifications_protocol")
  @@index([walletHash], name: "idx_notifications_wallet")
  @@index([status], name: "idx_notifications_status")
  @@index([idempotencyKey], name: "idx_notifications_idem")
  @@map("notifications")
}

// ── Webhooks ───────────────────────────────────────────────────────

model Webhook {
  id            String    @id @default(uuid()) @db.Uuid
  protocolId    String    @map("protocol_id") @db.Uuid
  url           String
  events        String[]  @default(["notification.delivered"])
  secretHash    String    @map("secret_hash") @db.VarChar(64)
  secretPrefix  String?   @map("secret_prefix") @db.VarChar(10)
  isActive      Boolean   @default(true) @map("is_active")
  failureCount  Int       @default(0) @map("failure_count") @db.SmallInt
  lastSuccessAt DateTime? @map("last_success_at") @db.Timestamptz()
  lastFailureAt DateTime? @map("last_failure_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  protocol   Protocol          @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@map("webhooks")
}

// ── Webhook Deliveries ─────────────────────────────────────────────

model WebhookDelivery {
  id             String   @id @default(uuid()) @db.Uuid
  webhookId      String   @map("webhook_id") @db.Uuid
  notificationId String?  @map("notification_id") @db.Uuid
  event          String   @db.VarChar(40)
  httpStatus     Int?     @map("http_status") @db.SmallInt
  latencyMs      Int?     @map("latency_ms")
  attempt        Int      @default(1) @db.SmallInt
  success        Boolean  @default(false)
  error          String?
  attemptedAt    DateTime @default(now()) @map("attempted_at") @db.Timestamptz()

  webhook      Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  notification Notification? @relation(fields: [notificationId], references: [id])

  @@index([webhookId, attemptedAt(sort: Desc)], name: "idx_webhook_del_webhook")
  @@map("webhook_deliveries")
}

// ── DKIM Keys ──────────────────────────────────────────────────────

model DkimKey {
  id          String    @id @default(uuid()) @db.Uuid
  protocolId  String?   @map("protocol_id") @db.Uuid
  domain      String    @db.VarChar(255)
  selector    String    @db.VarChar(63)
  publicKey   String    @map("public_key")
  kmsKeyId    String    @map("kms_key_id") @db.VarChar(255)
  dnsVerified Boolean   @default(false) @map("dns_verified")
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz()
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  protocol Protocol? @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@unique([domain, selector])
  @@map("dkim_keys")
}

// ── Bounce Tracking ────────────────────────────────────────────────

model EmailBounce {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String?  @map("notification_id") @db.Uuid
  walletHash     String?  @map("wallet_hash") @db.VarChar(64)
  bounceType     String   @map("bounce_type") @db.VarChar(10)
  sesMessageId   String?  @map("ses_message_id") @db.VarChar(100)
  diagnosticCode String?  @map("diagnostic_code")
  bouncedAt      DateTime @default(now()) @map("bounced_at") @db.Timestamptz()

  notification Notification? @relation(fields: [notificationId], references: [id])

  @@map("email_bounces")
}

// ── Digest Queue ───────────────────────────────────────────────────

model DigestQueue {
  id            String    @id @default(uuid()) @db.Uuid
  walletHash    String    @map("wallet_hash") @db.VarChar(64)
  protocolId    String    @map("protocol_id") @db.Uuid
  subject       String
  bodyArweaveId String?   @map("body_arweave_id") @db.VarChar(100)
  category      String    @db.VarChar(20)
  queuedAt      DateTime  @default(now()) @map("queued_at") @db.Timestamptz()
  scheduledFor  DateTime  @map("scheduled_for") @db.Timestamptz()
  sentAt        DateTime? @map("sent_at") @db.Timestamptz()

  protocol Protocol @relation(fields: [protocolId], references: [id])

  @@unique([walletHash, protocolId, queuedAt])
  @@map("digest_queue")
}
